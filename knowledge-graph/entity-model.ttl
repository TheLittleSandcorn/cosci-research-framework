@prefix cosci: <http://cosci.local/ontology#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Core class

cosci:KnowledgeDocument rdf:type rdfs:Class ;
    rdfs:label "Knowledge Document" .

# Properties

cosci:level rdf:type rdf:Property ;
    rdfs:domain cosci:KnowledgeDocument ;
    rdfs:range xsd:string .

cosci:status rdf:type rdf:Property ;
    rdfs:domain cosci:KnowledgeDocument ;
    rdfs:range xsd:string .

cosci:contentPreview rdf:type rdf:Property ;
    rdfs:domain cosci:KnowledgeDocument ;
    rdfs:range xsd:string .

